generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  manager
}

enum CourierSource {
  glovo
  bolt
}

enum PaymentStatus {
  pending
  paid
}

enum AuditAction {
  create
  update
  delete
  payment_confirmed
  upload
  rate_change
}

enum Currency {
  RON
  USD
  EUR
}

model Company {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logoUrl   String?
  primaryColor String? @default("#ffffff")
  currency  Currency @default(RON)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users           User[]
  couriers        Courier[]
  paymentBatches  PaymentBatch[]
  auditLogs       AuditLog[]
}

model User {
  id           String   @id @default(cuid())
  companyId    String
  email        String
  passwordHash String
  name         String
  role         UserRole @default(manager)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  paymentActions PaymentAction[]
  auditLogs      AuditLog[]

  @@unique([companyId, email])
}

model Courier {
  id         String        @id @default(cuid())
  companyId  String
  source     CourierSource
  externalId String
  name       String
  city       String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  company           Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  commissionHistory CommissionHistory[]
  taxHistory        TaxHistory[]
  paymentRecords    PaymentRecord[]
  adjustments       PaymentAdjustment[]

  @@unique([companyId, source, externalId])
  @@index([companyId, source])
  @@index([companyId, createdAt])
}

model CommissionHistory {
  id            String    @id @default(cuid())
  courierId     String
  value         Decimal   @db.Decimal(10, 4)
  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?

  courier Courier @relation(fields: [courierId], references: [id], onDelete: Cascade)

  @@index([courierId, effectiveFrom])
}

model TaxHistory {
  id            String    @id @default(cuid())
  courierId     String
  value         Decimal   @db.Decimal(12, 2)
  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?

  courier Courier @relation(fields: [courierId], references: [id], onDelete: Cascade)

  @@index([courierId, effectiveFrom])
}

model PaymentBatch {
  id           String        @id @default(cuid())
  companyId    String
  source       CourierSource
  periodStart  DateTime
  periodEnd    DateTime
  uploadedAt   DateTime      @default(now())
  fileReference String?
  uploadedById String?

  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  paymentRecords PaymentRecord[]

  @@index([companyId, source, periodStart])
}

model PaymentRecord {
  id                    String        @id @default(cuid())
  courierId             String
  batchId               String
  rawExcelData          Json
  periodCalculated      Decimal       @db.Decimal(12, 2)
  commissionUsed        Decimal       @db.Decimal(10, 4)
  taxUsed               Decimal       @db.Decimal(10, 4)
  commissionAmount      Decimal       @db.Decimal(12, 2) @default(0)
  taxAmount             Decimal       @db.Decimal(12, 2) @default(0)
  calculatedGrandPayment Decimal      @db.Decimal(12, 2)
  userReceivableAmount  Decimal       @db.Decimal(12, 2) @default(0)
  previousDueAmount     Decimal       @db.Decimal(12, 2) @default(0)
  adjustmentAmount      Decimal       @db.Decimal(12, 2) @default(0)
  totalPayable          Decimal       @db.Decimal(12, 2)
  previousDueReference  String?
  status                PaymentStatus @default(pending)
  createdAt             DateTime      @default(now())

  courier        Courier          @relation(fields: [courierId], references: [id], onDelete: Cascade)
  batch          PaymentBatch     @relation(fields: [batchId], references: [id], onDelete: Cascade)
  paymentActions PaymentAction[]
  previousDueRef PaymentRecord?   @relation("DueCarryForward", fields: [previousDueReference], references: [id])
  carriedForward PaymentRecord[]  @relation("DueCarryForward")
  sourceAdjustments  PaymentAdjustment[] @relation("AdjustmentSource")
  appliedAdjustments PaymentAdjustment[] @relation("AdjustmentApplied")

  @@index([courierId, createdAt])
  @@index([batchId])
  @@index([status])
}

/// Retroactive correction for an already-paid week; carried into the next pending payout.
model PaymentAdjustment {
  id                String   @id @default(cuid())
  courierId         String
  sourceRecordId    String
  appliedToRecordId String?
  amount            Decimal  @db.Decimal(12, 2)
  reason            String?
  createdAt         DateTime @default(now())

  courier         Courier        @relation(fields: [courierId], references: [id], onDelete: Cascade)
  sourceRecord    PaymentRecord  @relation("AdjustmentSource", fields: [sourceRecordId], references: [id], onDelete: Cascade)
  appliedToRecord PaymentRecord? @relation("AdjustmentApplied", fields: [appliedToRecordId], references: [id])

  @@index([courierId, appliedToRecordId])
  @@index([sourceRecordId])
}

model PaymentAction {
  id              String   @id @default(cuid())
  paymentRecordId String
  confirmedById   String
  confirmedAt     DateTime @default(now())
  notes           String?

  paymentRecord PaymentRecord @relation(fields: [paymentRecordId], references: [id], onDelete: Cascade)
  confirmedBy   User          @relation(fields: [confirmedById], references: [id])

  @@index([paymentRecordId])
}

model AuditLog {
  id         String      @id @default(cuid())
  companyId  String
  userId     String?
  action     AuditAction
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime    @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id])

  @@index([companyId, createdAt])
  @@index([entityType, entityId])
}
